{
  "version": 1,
  "trainer_path": "exp/engram-hc/train_gpt.py",
  "launcher": {
    "nproc_per_node": 8,
    "master_port_base": 29500
  },
  "defaults": {
    "data_path": "./data/datasets/fineweb10B_sp1024",
    "tokenizer_path": "./data/tokenizers/fineweb_1024_bpe.model",
    "vocab_size": 1024,
    "train_batch_tokens": 524288,
    "train_seq_len": 1024,
    "warmup_steps": 20,
    "warmdown_iters": 1200,
    "enable_wandb": 1,
    "wandb_mode": "offline",
    "wandb_project": "bag-of-tricks-for-transformers",
    "num_layers": 9,
    "model_dim": 512,
    "num_heads": 8,
    "num_kv_heads": 4,
    "mlp_mult": 2,
    "engram_enabled": 1,
    "engram_layer_ids": "1,4,8",
    "engram_max_ngram": 3,
    "engram_heads_per_ngram": 4,
    "engram_embed_per_ngram": 128,
    "engram_vocab_sizes": "8192,8192",
    "engram_vocab_multiplier": 8,
    "engram_kernel_size": 4,
    "engram_pad_id": 0,
    "engram_use_tokenizer_compression": 1,
    "engram_use_hc": 1,
    "engram_hc_mult": 4,
    "engram_embed_lr": 0.02
  },
  "experiments": [
    {
      "name": "engram-hc-fixed_time_10min",
      "trainer_path": "exp/engram-hc/train_gpt.py",
      "control": {
        "mode": "fixed_compute",
        "target_wallclock_seconds": 600,
        "iterations_cap": 1000000
      }
    },
    {
      "name": "engram-hc-fixed_tokens_10b",
      "trainer_path": "exp/engram-hc/train_gpt.py",
      "control": {
        "mode": "fixed_tokens",
        "target_train_tokens": 10000000000
      }
    }
  ]
}
