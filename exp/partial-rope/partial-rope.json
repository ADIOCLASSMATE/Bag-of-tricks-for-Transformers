{
    "version": 1,
    "trainer_path": "exp/partial-rope/train_gpt.py",
    "launcher": {
        "nproc_per_node": 8,
        "master_port_base": 29500
    },
    "defaults": {
        "data_path": "./data/datasets/fineweb10B_sp1024",
        "tokenizer_path": "./data/tokenizers/fineweb_1024_bpe.model",
        "vocab_size": 1024,
        "train_batch_tokens": 524288,
        "train_seq_len": 1024,
        "warmup_steps": 50,
        "warmdown_iters": 1500,
        "enable_wandb": 1,
        "wandb_mode": "offline",
        "wandb_project": "bag-of-tricks-for-transformers",
        "wandb_api_key": "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",
        "num_layers": 9,
        "model_dim": 512,
        "num_heads": 8,
        "num_kv_heads": 4,
        "mlp_mult": 2,
        "rope_dims": 16,
        "tied_embed_lr": 0.05,
        "embed_lr": 0.6,
        "head_lr": 0.008,
        "matrix_lr": 0.04,
        "scalar_lr": 0.04,
        "muon_momentum": 0.95,
        "muon_backend_steps": 5,
        "muon_momentum_warmup_start": 0.85,
        "muon_momentum_warmup_steps": 800,
        "grad_clip_norm": 0.0
    },
    "experiments": [
        {
            "name": "partial-rope-16-fixed_time_10min",
            "trainer_path": "exp/partial-rope/train_gpt.py",
            "control": {
                "mode": "fixed_compute",
                "target_wallclock_seconds": 600,
                "iterations_cap": 1000000
            }
        },
        {
            "name": "partial-rope-16-fixed_tokens_10b",
            "trainer_path": "exp/partial-rope/train_gpt.py",
            "control": {
                "mode": "fixed_tokens",
                "target_train_tokens": 10000000000
            }
        }
    ]
}
