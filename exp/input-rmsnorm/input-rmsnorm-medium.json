{
  "version": 1,
  "trainer_path": "exp/input-rmsnorm/train_gpt.py",
  "launcher": {
    "nproc_per_node": 4,
    "master_port_base": 29500
  },
  "defaults": {
    "data_path": "./data/datasets/fineweb-edu_100BT_gpt2",
    "tokenizer_path": "gpt2",
    "vocab_size": 50257,
    "train_batch_tokens": 524288,
    "train_seq_len": 1024,
    "warmup_steps": 50,
    "warmdown_iters": 2861,
    "enable_wandb": 1,
    "wandb_mode": "offline",
    "wandb_project": "bag-of-tricks-for-transformers",
    "num_layers": 18,
    "model_dim": 1024,
    "num_heads": 16,
    "num_kv_heads": 8,
    "mlp_mult": 2,
    "tied_embed_lr": 0.05,
    "embed_lr": 0.6,
    "head_lr": 0.008,
    "matrix_lr": 0.04,
    "scalar_lr": 0.04,
    "muon_momentum": 0.95,
    "muon_backend_steps": 5,
    "muon_momentum_warmup_start": 0.8,
    "muon_momentum_warmup_steps": 953,
    "grad_clip_norm": 0.0,
    "wandb_entity": "Bag-of-Tricks",
    "wandb_group": "medium-ablation",
    "tokenizer_type": "gpt2"
  },
  "experiments": [
    {
      "name": "input-rmsnorm-medium-fixed_tokens_10b",
      "trainer_path": "exp/input-rmsnorm/train_gpt.py",
      "control": {
        "mode": "fixed_tokens",
        "target_train_tokens": 10000000000
      }
    }
  ]
}
