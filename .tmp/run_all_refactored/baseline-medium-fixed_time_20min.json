{
  "version": 1,
  "trainer_path": "exp/baseline/train_gpt_refactor.py",
  "launcher": {
    "nproc_per_node": 4,
    "master_port_base": 29500
  },
  "defaults": {
    "data_path": "./data/datasets/fineweb10B_sp1024",
    "tokenizer_path": "./data/tokenizers/fineweb_1024_bpe.model",
    "vocab_size": 1024,
    "train_batch_tokens": 524288,
    "train_seq_len": 1024,
    "warmup_steps": 50,
    "warmdown_iters": 800,
    "enable_wandb": 1,
    "wandb_mode": "online",
    "wandb_project": "bag-of-tricks-for-transformers",
    "wandb_entity": "Bag-of-Tricks",
    "wandb_group": "medium-ablation",
    "num_layers": 18,
    "model_dim": 1024,
    "num_heads": 16,
    "num_kv_heads": 8,
    "mlp_mult": 2,
    "tied_embed_lr": 0.05,
    "embed_lr": 0.6,
    "head_lr": 0.008,
    "matrix_lr": 0.04,
    "scalar_lr": 0.04,
    "muon_momentum": 0.95,
    "muon_backend_steps": 5,
    "muon_momentum_warmup_start": 0.85,
    "muon_momentum_warmup_steps": 800,
    "grad_clip_norm": 0.0
  },
  "experiments": [
    {
      "name": "baseline-medium-fixed_time_20min",
      "trainer_path": "exp/baseline/train_gpt_refactor.py",
      "control": {
  "mode": "fixed_compute",
  "target_wallclock_seconds": 1200,
  "iterations_cap": 1000000
}
    }
  ]
}
